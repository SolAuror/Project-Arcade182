  entries:
  - kind: 0
    category: 0
    title: STABLE ATOM
    symbol: H-1
    description: INERT SAMPLE. POPS ON CONTACT. COLLECT EVERY MARKED SAMPLE TO CLEAR
      THE RUN.
    icon: {fileID: 21300000, guid: aee1affc1f04c9844993bc51c569717d, type: 3}
    accent: {r: 0.42352942, g: 0.9098039, b: 0.9607843, a: 1}
  - kind: 1
    category: 0
    title: QUANTUM ATOM
    symbol: Q-1
    description: A SUPERPOSED SAMPLE. POP IT FOR A BONUS EFFECT - BOOST, SPLIT OR
      RESTOCK.
    icon: {fileID: 21300000, guid: b3a9938f7a202d948a7214ecd22bffe7, type: 3}
    accent: {r: 0.32941177, g: 0.9607843, b: 0.50980395, a: 1}
  - kind: 2
    category: 1
    title: BAFFLE PLATE
    symbol: PB-82
    description: INERT SHIELDING. PROBES BOUNCE OFF - USE IT TO BANK SHOTS.
    icon: {fileID: 21300000, guid: 49477bfd2ea98e947a86b002dab714c3, type: 3}
    accent: {r: 0.68235296, g: 0.7372549, b: 0.78431374, a: 1}
  - kind: 3
    category: 1
    title: SWEEP BAFFLE
    symbol: PB-82
    description: SHIELDING ON PATROL. TIME YOUR SHOT AROUND ITS SWEEP.
    icon: {fileID: 21300000, guid: 5652374177f900b429541b7243830466, type: 3}
    accent: {r: 0.68235296, g: 0.7372549, b: 0.78431374, a: 1}
  - kind: 4
    category: 0
    title: DRIFTER ATOM
    symbol: D-2
    description: MIGRATES ABOUT THE CHAMBER AND DODGES CLUTTER. LEAD YOUR SHOT.
    icon: {fileID: 21300000, guid: 0756864550b58e94ebe10cd5db417f4d, type: 3}
    accent: {r: 1, g: 0.72156864, b: 0.3019608, a: 1}
  - kind: 5
    category: 1
    title: ROTOR ARRAY
    symbol: PB-82
    description: A SPINNING SHIELD CROSS. FIRE THROUGH THE GAPS - OR OFF THE BLADES.
    icon: {fileID: 21300000, guid: 8218ea9f5c25b6a4aadf3c1fc30974ac, type: 3}
    accent: {r: 0.68235296, g: 0.7372549, b: 0.78431374, a: 1}
  - kind: 6
    category: 0
    title: UNSTABLE ISOTOPE
    symbol: T-3
    description: DEFLECTS DIRECT FIRE. ONLY A REBOUND SHOT CAN POP IT.
    icon: {fileID: 21300000, guid: 8083eea4c73074847b02ddb13d1645b0, type: 3}
    accent: {r: 1, g: 0.30980393, b: 0.72156864, a: 1}
  - kind: 7
    category: 2
    title: MICRO SINGULARITY
    symbol: BH-X
    description: ITS PULL BENDS EVERY PROBE. CURVE SHOTS AROUND COVER.
    icon: {fileID: 21300000, guid: 41e4f6cdf20ca7442a75b570d67f929d, type: 3}
    accent: {r: 0.6901961, g: 0.42352942, b: 1, a: 1}
  - kind: 8
    category: 0
    title: ORBITAL CLUSTER
    symbol: LI-7
    description: BOUND SAMPLES ORBITING A NUCLEUS. POP EVERY ORBITAL TO BREAK THE
      BOND.
    icon: {fileID: 21300000, guid: 8857bdc8f8041ff42bd17e595e168e95, type: 3}
    accent: {r: 0.42352942, g: 0.9098039, b: 0.9607843, a: 1}
  - kind: 9
    category: 0
    title: VOLATILE NUCLEUS
    symbol: U-235
    description: CRITICAL PAYLOAD. DETONATES ON IMPACT AND POPS ITS NEIGHBOURS.
    icon: {fileID: 21300000, guid: 771ea5b8a896feb4893331822072f203, type: 3}
    accent: {r: 1, g: 0.5411765, b: 0.23921569, a: 1}
  - kind: 10
    category: 2
    title: WORMHOLE PAIR
    symbol: WH-2
    description: LINKED APERTURES. A PROBE ENTERING ONE IS EJECTED FROM ITS TWIN.
    icon: {fileID: 21300000, guid: 2e1cbaca05a238449869a7744e6392f3, type: 3}
    accent: {r: 1, g: 0.5411765, b: 0.23921569, a: 1}
  - kind: 11
    category: 0
    title: POLARIZED MATTER
    symbol: P+/-
    description: CHARGED SAMPLES PULL OPPOSITE PROBES AND REPEL LIKE ONES. FLIP CHARGE
      AT THE GATE.
    icon: {fileID: 21300000, guid: c8a9acfea1bee2c4987ba8a13e732d87, type: 3}
    accent: {r: 1, g: 0.42352942, b: 0.72156864, a: 1}
